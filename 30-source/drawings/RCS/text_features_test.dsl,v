@# text_features_test.dsl — exercises all new text features

eid off
dim off

dir 90

# 1. Element naming + textline (text along a named line, centered, bold markup)
l 14 @@main_wall
textline "**Main Wall**" main_wall center 12

# 2. textbreak (text obscuring the line with a white border box)
l 14 @@section_line A=0,2
textbreak "Section A" section_line center 10

# 3. textstyle: sets global font and size for subsequent text
textstyle 9 font=serif

# 4. textbox with word wrap (2 ft wide — wraps at ~22 chars)
tbox 2 1.5 "A long note that wraps inside this box" left wrap 9 A=0,5

# 5. Inline markup on a plain label
lb "Normal *italic* and **bold** text" 11 A=0,8

# 6. rect with @@name and textappend (rect grows downward)
rect 4 0.6 @@schedule "**Schedule**" C="lightgray" A=0,11
textappend "Area: 168 sq ft" schedule
textappend "*Finish:* Hardwood" schedule left

# 7. Escaped asterisk in label text (\* = literal asterisk; $ needs no escape)
lb "Cost: $4.50/sq\*ft" 9 A=0,14
@
