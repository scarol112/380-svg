1.1
log
@Initial tuple smoke test (issue #22)
@
text
@direction 90

# --- declaration forms ---
tuple empty
tuple p
p = (3, 4)
tuple q = 1, 2, 3
tuple r = q
tuple m = ("name", 5, "tag", 0)

# --- indexing read ---
numeric n = (p[0] + p[1])
label "n=${n}"

# --- element assignment ---
p[0] = 10
p[1] = 20

# --- element-wise math ---
tuple sum2 = p + q
tuple scaled = p * 3
tuple s2 = m + ("_x", 1, "_y", 1)

# --- len() on a tuple ---
numeric plen = (len(p))
label "plen=${plen}"

# --- cursor as tuple ---
mto 5 5
tuple here = $__cursor
label "here"
mto 10 10
mto $here

# --- coord-bearing commands with tuple arg ---
tuple origin = 1, 1
r 10 8 $origin
r 10 8 (2, 2)
r 10 8 2,2
@
