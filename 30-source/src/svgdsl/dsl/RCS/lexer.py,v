@import re
from dataclasses import dataclass


@@dataclass
class Token:
    kind: str   # MEASUREMENT | PX | COORD4 | COORD | ABSOLUTE | QUOTED | KEYWORD | WORD | NUMBER
    value: str
    lineno: int


_FEET_INCHES = re.compile(r"(\d+)'(\d+)\"?")
_FEET_ONLY   = re.compile(r"(\d+(?:\.\d+)?)'")
_INCHES_ONLY = re.compile(r"(\d+(?:\.\d+)?)\"|\"")
_NUMBER      = re.compile(r"\d+(?:\.\d+)?")
_PX          = re.compile(r"(\d+(?:\.\d+)?)px", re.IGNORECASE)
_COORD4      = re.compile(r"(-?\d+(?:\.\d+)?),(-?\d+(?:\.\d+)?),(-?\d+(?:\.\d+)?),(-?\d+(?:\.\d+)?)")
_COORD       = re.compile(r"(-?\d+(?:\.\d+)?),(-?\d+(?:\.\d+)?)")
_ABSOLUTE    = re.compile(r"A=(-?\d+(?:\.\d+)?),(-?\d+(?:\.\d+)?)", re.IGNORECASE)
_QUOTED      = re.compile(r'"([^"]*)"')
_QUOTED_SINGLE = re.compile(r"'([^']*)'")
_COLOR_ELEM  = re.compile(r'C=(?:"([^"]*)"|(\w+))', re.IGNORECASE)


def tokenize(raw: str, lineno: int) -> list[Token]:
    tokens: list[Token] = []
    i = 0
    while i < len(raw):
        if raw[i].isspace():
            i += 1
            continue

        # Try each pattern in priority order
        m = _ABSOLUTE.match(raw, i)
        if m:
            tokens.append(Token("ABSOLUTE", m.group(), lineno))
            i = m.end()
            continue

        m = _COLOR_ELEM.match(raw, i)
        if m:
            color_val = m.group(1) if m.group(1) is not None else m.group(2)
            tokens.append(Token("COLOR_ELEM", color_val, lineno))
            i = m.end()
            continue

        m = _QUOTED.match(raw, i)
        if m:
            content = m.group(1).replace('\\n', '\n')
            tokens.append(Token("QUOTED", content, lineno))
            i = m.end()
            continue

        # Single-quoted string. Safe to try here because feet/inches patterns
        # below all require a digit immediately before the quote.
        m = _QUOTED_SINGLE.match(raw, i)
        if m:
            content = m.group(1).replace('\\n', '\n')
            tokens.append(Token("QUOTED", content, lineno))
            i = m.end()
            continue

        m = _PX.match(raw, i)
        if m:
            tokens.append(Token("PX", m.group(1), lineno))
            i = m.end()
            continue

        m = _FEET_INCHES.match(raw, i)
        if m:
            tokens.append(Token("MEASUREMENT", m.group(), lineno))
            i = m.end()
            continue

        m = _FEET_ONLY.match(raw, i)
        if m:
            tokens.append(Token("MEASUREMENT", m.group(), lineno))
            i = m.end()
            continue

        m = _INCHES_ONLY.match(raw, i)
        if m:
            tokens.append(Token("MEASUREMENT", m.group(), lineno))
            i = m.end()
            continue

        m = _COORD4.match(raw, i)
        if m:
            tokens.append(Token("COORD4", m.group(), lineno))
            i = m.end()
            continue

        m = _COORD.match(raw, i)
        if m:
            tokens.append(Token("COORD", m.group(), lineno))
            i = m.end()
            continue

        m = _NUMBER.match(raw, i)
        if m:
            tokens.append(Token("NUMBER", m.group(), lineno))
            i = m.end()
            continue

        # Word token (type names, keywords)
        end = i
        while end < len(raw) and not raw[end].isspace():
            end += 1
        tokens.append(Token("WORD", raw[i:end], lineno))
        i = end

    return tokens


def parse_measurement(token: Token) -> float:
    """Convert a MEASUREMENT or NUMBER token to feet (float)."""
    raw = token.value

    m = _FEET_INCHES.fullmatch(raw)
    if m:
        return int(m.group(1)) + int(m.group(2)) / 12.0

    m = _FEET_ONLY.fullmatch(raw)
    if m:
        return float(m.group(1))

    m = _INCHES_ONLY.fullmatch(raw)
    if m:
        return float(m.group(1)) / 12.0

    # plain number = feet
    return float(raw)


def parse_coord(token: Token) -> tuple[float, float]:
    m = _COORD.fullmatch(token.value)
    if not m:
        raise ValueError(f"Not a coord: {token.value!r}")
    return float(m.group(1)), float(m.group(2))


def parse_coord4(token: Token) -> tuple[float, float, float, float]:
    m = _COORD4.fullmatch(token.value)
    if not m:
        raise ValueError(f"Not a coord4: {token.value!r}")
    return float(m.group(1)), float(m.group(2)), float(m.group(3)), float(m.group(4))


def parse_absolute(token: Token) -> tuple[float, float]:
    m = _ABSOLUTE.fullmatch(token.value)
    if not m:
        raise ValueError(f"Not an absolute offset: {token.value!r}")
    return float(m.group(1)), float(m.group(2))
@


